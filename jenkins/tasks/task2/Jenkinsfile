pipeline {
  agent { label 'linux-agent' }

  options {
    timestamps()
    skipDefaultCheckout(true)
  }

  environment {
    // Create this Jenkins Secret Text credential in advance.
    SLACK_WEBHOOK = credentials('slack-webhook')
    FAILED_STAGE = 'Unknown'
  }

  stages {
    stage('Checkout') {
      steps {
        script { env.FAILED_STAGE = 'Checkout' }
        checkout scm
      }
      post {
        failure {
          script {
            env.FAILED_STAGE = 'Checkout'
          }
        }
      }
    }

    stage('Setup Node') {
      steps {
        script { env.FAILED_STAGE = 'Setup Node' }
        sh '''
          set -e
          if ! command -v npm >/dev/null 2>&1; then
            echo "npm not found, installing Node.js 16 (Amazon Linux 2 compatible)..."
            curl -fsSL https://rpm.nodesource.com/setup_16.x | sudo bash -
            sudo yum clean all
            sudo yum makecache -y
            # NodeSource nodejs package already contains npm; do not install separate npm package.
            sudo yum install -y nodejs
          fi
          node -v
          npm -v
        '''
      }
      post {
        failure {
          script {
            env.FAILED_STAGE = 'Setup Node'
          }
        }
      }
    }

    stage('Build') {
      steps {
        script { env.FAILED_STAGE = 'Build' }
        dir('app') {
          sh 'npm ci'
          sh 'npm run build'
        }
      }
      post {
        failure {
          script {
            env.FAILED_STAGE = 'Build'
          }
        }
      }
    }

    stage('Test') {
      failFast true
      parallel {
        stage('Unit Tests') {
          steps {
            script { env.FAILED_STAGE = 'Unit Tests' }
            dir('app') {
              sh 'npm run test:unit'
            }
          }
          post {
            always {
              junit allowEmptyResults: false, testResults: 'app/reports/junit/unit/junit.xml'
            }
            failure {
              script {
                env.FAILED_STAGE = 'Unit Tests'
              }
            }
          }
        }

        stage('Integration Tests') {
          steps {
            script { env.FAILED_STAGE = 'Integration Tests' }
            dir('app') {
              sh 'npm run test:integration'
            }
          }
          post {
            always {
              junit allowEmptyResults: false, testResults: 'app/reports/junit/integration/junit.xml'
            }
            failure {
              script {
                env.FAILED_STAGE = 'Integration Tests'
              }
            }
          }
        }
      }
      post {
        failure {
          script {
            if (!env.FAILED_STAGE || env.FAILED_STAGE == 'Unknown') {
              env.FAILED_STAGE = env.STAGE_NAME
            }
          }
        }
      }
    }

    stage('Package') {
      steps {
        script { env.FAILED_STAGE = 'Package' }
        dir('app') {
          sh 'npm run package'
        }
      }
      post {
        failure {
          script {
            env.FAILED_STAGE = 'Package'
          }
        }
      }
    }

    stage('Deploy') {
      steps {
        script { env.FAILED_STAGE = 'Deploy' }
        dir('app') {
          sh 'npm run deploy'
        }
      }
      post {
        failure {
          script {
            env.FAILED_STAGE = 'Deploy'
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'app/dist/*.tgz, app/reports/junit/**/*.xml', allowEmptyArchive: true
    }

    success {
      script {
        def resp = sh(
          script: '''
            set +e
            body=$(curl -sS -w "\\nHTTP_STATUS:%{http_code}" -X POST -H 'Content-type: application/json' \\
              --data "{\"text\":\"SUCCESS: $JOB_NAME #$BUILD_NUMBER - $BUILD_URL\"}" \\
              "$SLACK_WEBHOOK")
            echo "$body"
          ''',
          returnStdout: true
        ).trim()
        echo "Slack success notification response: ${resp}"
      }
    }

    failure {
      script {
        def resp = sh(
          script: '''
            set +e
            body=$(curl -sS -w "\\nHTTP_STATUS:%{http_code}" -X POST -H 'Content-type: application/json' \\
              --data "{\"text\":\"FAILURE: $JOB_NAME #$BUILD_NUMBER failed at stage $FAILED_STAGE. Build: $BUILD_URL\"}" \\
              "$SLACK_WEBHOOK")
            echo "$body"
          ''',
          returnStdout: true
        ).trim()
        echo "Slack failure notification response: ${resp}"
      }
    }
  }
}